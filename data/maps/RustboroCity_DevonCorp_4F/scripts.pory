script RustboroCity_DevonCorp_4F_EventScript_OfferShiny {
	setvar(VAR_TEMP_2, 0)
	msgbox(format("Oh, I almost forgot!"))
	showmoneybox(0, 0)
	msgbox(RustboroCity_DevonCorp_4F_Text_ShinyOffer)
	multichoicedefault(20, 8, MULTI_YESNO, 1, FALSE)

	if (var(VAR_RESULT) == 0) {
		// "Yes"
		checkmoney(50000)

		if (var(VAR_RESULT) == TRUE) {
			removemoney(50000)
			playse(SE_SHOP)
			waitse
			hidemoneybox()
			setvar(VAR_TEMP_2, 1)
			msgbox(format("Excellent! I'll prepare a special variant for you."))
		} else {
			hidemoneybox()
			msgbox(RustboroCity_DevonCorp_4F_Text_ShinyNoMoney)
			setvar(VAR_RESULT, 0)
    		releaseall
			return
		}
	} else {
		// "No"
		hidemoneybox()
		msgbox(format("OK, I'll get to work…"))
	}

	// Take Unstable DNA item
	setvar(VAR_0x8004, ITEM_UNSTABLE_DNA)
	call(Common_EventScript_PlayerHandedOverTheItem)

	goto(RustboroCity_DevonCorp_4F_EventScript_GiveLegendary)
}

script RustboroCity_DevonCorp_4F_EventScript_DrParkerEnd {
    msgbox(format("If you come across any Unstable DNA samples, please come see me!"))
	setvar(VAR_RESULT, 0)
    releaseall
}

script RustboroCity_DevonCorp_4F_EventScript_HasMon {
	msgbox(RustboroCity_DevonCorp_4F_Text_HasMonLine)
	setvar(VAR_RESULT, 0)
	releaseall
}

script RustboroCity_DevonCorp_4F_EventScript_GiveLegendary {
    switch (var(VAR_TEMP_1)) {
	// Order of operations:
	// Buffer species name
	// Prepare species variable for transfer
	// Give level 5 mon in a Beast Ball
	// Set obtained flag if it was successful
        case 0:  // Mewtwo
            bufferspeciesname(STR_VAR_1, SPECIES_MEWTWO_V)
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_MEWTWO_V)
            givemon(SPECIES_MEWTWO_V, 5, ITEM_NONE, ITEM_BEAST_BALL)
			if (var(VAR_RESULT) < MON_CANT_GIVE) {
				setflag(FLAG_OBTAINED_MEWTWO_LINE)
			}
            break
        case 1:  // Articuno
            bufferspeciesname(STR_VAR_1, SPECIES_ARTICUNO_V)
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ARTICUNO_V)
            givemon(SPECIES_ARTICUNO_V, 5, ITEM_NONE, ITEM_BEAST_BALL)
			if (var(VAR_RESULT) < MON_CANT_GIVE) {
				setflag(FLAG_OBTAINED_BIRD_LINE)
			}
            break
        case 2:  // Zapdos
			bufferspeciesname(STR_VAR_1, SPECIES_ZAPDOS_V)
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_ZAPDOS_V)
			givemon(SPECIES_ZAPDOS_V, 5, ITEM_NONE, ITEM_BEAST_BALL)
			if (var(VAR_RESULT) < MON_CANT_GIVE) {
				setflag(FLAG_OBTAINED_BIRD_LINE)
			}
			break
		case 3:  // Moltres
			bufferspeciesname(STR_VAR_1, SPECIES_MOLTRES_V)
			setvar(VAR_TEMP_TRANSFERRED_SPECIES, SPECIES_MOLTRES_V)
			givemon(SPECIES_MOLTRES_V, 5, ITEM_NONE, ITEM_BEAST_BALL)
			if (var(VAR_RESULT) < MON_CANT_GIVE) {
				setflag(FLAG_OBTAINED_BIRD_LINE)
			}
			break
		case 4:  // Raikou
