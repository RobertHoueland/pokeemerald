			}
			break
		default:
			// shouldn't get here
			goto(RustboroCity_DevonCorp_4F_EventScript_DrParkerEnd)
    }

	// Successful give?
	if (var(VAR_RESULT) != MON_CANT_GIVE) {
		// Make shiny if player paid for it
		if (var(VAR_TEMP_2) == 1) {
			callnative(Script_SetLastGiftMonShiny)
		}

		// flash screen and do cry
		playmoncry(VAR_TEMP_TRANSFERRED_SPECIES, CRY_MODE_ENCOUNTER)
		fadescreenspeed(FADE_TO_BLACK, 1)
		msgbox(format("{STR_VAR_1} materialized from the Unstable DNA!"))
		fadescreenspeed(FADE_FROM_BLACK, 1)
		waitmoncry

        playfanfare(MUS_OBTAIN_ITEM)
        message(format("{PLAYER} received {STR_VAR_1}!"))
        waitmessage
        waitfanfare
	}

    if (var(VAR_RESULT) == MON_GIVEN_TO_PARTY) {
        msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
        if (var(VAR_RESULT) == YES) {
            call(Common_EventScript_GetGiftMonPartySlot)
            call(Common_EventScript_NameReceivedPartyMon)
        }
        closemessage
    } elif (var(VAR_RESULT) == MON_GIVEN_TO_PC) {
        call(Common_EventScript_TransferredToPC)
        msgbox(gText_NicknameThisPokemon, MSGBOX_YESNO)
        if (var(VAR_RESULT) == YES) {
            call(Common_EventScript_NameReceivedBoxMon)
        }
        closemessage
    } else {
        goto(Common_EventScript_NoMoreRoomForPokemon)
    }

    msgbox(format("DR. PARKER: Enjoy your new Proto-Legend!"))
    setvar(VAR_RESULT, 0)
    releaseall
}