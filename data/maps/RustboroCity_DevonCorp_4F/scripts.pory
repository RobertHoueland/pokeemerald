raw `
RustboroCity_DevonCorp_4F_MapScripts::
	.byte 0
`

movement DrParkerExcited_MoveLeft {
	walk_left * 2
	face_down
	delay_16
	walk_up * 2
	face_left
	delay_16
	walk_right
	face_up
	delay_16
	walk_down * 2
	walk_right
	face_player
}

movement DrParkerExcited_MoveRight {
	walk_right * 2
	face_down
	delay_16
	walk_up * 2
	face_left
	delay_16
	walk_right
	face_up
	delay_16
	walk_down * 2
	walk_left * 3
	face_player
}

text RustboroCity_DevonCorp_4F_Text_DrParkerGreeting {
	format("Oh! I didn't see you there!\p"
	       "I'm on the verge of a breakthrough\nin my research.\p"
		   "All I need is a sample of Unstable DNA…")
}

text RustboroCity_DevonCorp_4F_Text_DrParkerFoundDna {
	format("DR. PARKER: Wait… you found an Unstable DNA sample?\p"
	       "What an incredible day this is!!!")
}

text RustboroCity_DevonCorp_4F_Text_DrParkerMainExplanation {
	format("DR. PARKER: Wait…\nYou got it from ROXANNE?\p"
	       "How in the world did ROXANNE\nget that Unstable DNA?\p"
		   "If you are willing to part with it…\n"
		   "I can finally stabilize my lab-grown\lexperiments.\p"
		   "I call them… PROTO-LEGENDS!\p"
		   "They are breathtaking POKéMON, forged with fragments of legendary power.\p"
		   "Now, don't expect them to be perfect…\n"
		   "They remain in the early stages of\ldevelopment.\p"
		   "Though my research shows remarkable\n"
		   "traits. They harness abilities unlike\ltheir legendary counterparts.\p"
		   "And they mutate with unusual frequency!\p"
		   "Keep in mind, each prototype belongs\nto a distinct genetic line.\p"
		   "Meaning I can only create one POKéMON\n"
		   "per lineage. This avoids conflicts\lwith their unstable genetics.")
}

text RustboroCity_DevonCorp_4F_Text_DrParkerReturnWithDna {
	format("DR. PARKER: Is that Unstable DNA I see?\p"
		   "Splendid! My research continues\nto evolve!")
}

text RustboroCity_DevonCorp_4F_Text_ShinyOffer {
	format("I could attempt to alter your Proto-Legend's color scheme.\p"
	       "But it requires expensive materials.\n"
		   "It'll cost you ¥50000.")
}

text RustboroCity_DevonCorp_4F_Text_ShinyNoMoney {
	"Come back when you have ¥50000.\nYour Proto-Legend will be waiting!"
}

text RustboroCity_DevonCorp_4F_Text_HasMonLine {
	format("Wait… I see you already possess a\nProto-Legend from that genetic line.\p"
	       "I cannot create multiple prototypes\nfrom the same lineage.\p"
		   "The genetic instability would be\ntoo unpredictable.")
}

text RustboroCity_DevonCorp_4F_Text_TableProtoLegends {
	format("Blueprints and sketches cover the\ntable.\p"
	       "Each page is labeled: PROTO-LEGENDS.\p"
		   "Several failed drafts are crossed out:\n"
		   "“Mutation cascade risk: CRITICAL.”")
}

text RustboroCity_DevonCorp_4F_Text_MonitorMutations {
	format("A DEVON monitor displays mutation logs.\p"
	       "Proto-Legends adapt rapidly under stress.\p"
		   "Note: sudden mutations can alter abilities and battle tendencies.")
}

text RustboroCity_DevonCorp_4F_Text_DisplayGeneticLines {
	format("A warning label reads:\nGENETIC LINEAGE CONTAINMENT PROTOCOL\p"
		   "Only one Proto-Legend may be stabilized per genetic line.")
}

text RustboroCity_DevonCorp_4F_Text_DisplayExperiment {
	"A glass chamber hums softly.\nA glowing orb pulses inside."
}

script RustboroCity_DevonCorp_4F_EventScript_DrParker {
    lockall
    goto_if_set(FLAG_MET_DR_PARKER, Met_DrParker)
	GetDirectionToFace (VAR_TEMP_0, LOCALID_DR_PARKER, OBJ_EVENT_ID_PLAYER)

	msgbox(format("Come on… so close…"))
    faceplayer
	msgbox(RustboroCity_DevonCorp_4F_Text_DrParkerGreeting)
	// TODO backstory…

	checkitem(ITEM_UNSTABLE_DNA, 1)
	if (var(VAR_RESULT) == FALSE) {
		goto(RustboroCity_DevonCorp_4F_EventScript_DrParkerEnd)
	}

	playse(SE_PIN)
	applymovement(LOCALID_DR_PARKER, Common_Movement_ExclamationMark)
	waitse
	waitmovement(0)
	msgbox(RustboroCity_DevonCorp_4F_Text_DrParkerFoundDna)

	if (var(VAR_TEMP_0) == DIR_WEST) {
		// if NPC had to look left, move on right side
		applymovement(LOCALID_DR_PARKER, DrParkerExcited_MoveRight)
	} else {
		// otherwise (if NPC looked right or down)
		applymovement(LOCALID_DR_PARKER, DrParkerExcited_MoveLeft)
	}
	waitmovement(0)

	msgbox(RustboroCity_DevonCorp_4F_Text_DrParkerMainExplanation)
    setflag(FLAG_MET_DR_PARKER)
	goto(FirstMeet_DrParker)

Met_DrParker:
    faceplayer
	checkitem(ITEM_UNSTABLE_DNA, 1)
	if (var(VAR_RESULT) == FALSE) {
		goto(RustboroCity_DevonCorp_4F_EventScript_DrParkerEnd)
	}
	msgbox(RustboroCity_DevonCorp_4F_Text_DrParkerReturnWithDna)
FirstMeet_DrParker:
	msgbox(format("Please, accept a Proto-Legend as a thank you for the DNA sample."))
	goto(RustboroCity_DevonCorp_4F_EventScript_SelectRegion)
}

script RustboroCity_DevonCorp_4F_EventScript_SelectRegion {
    message("From which region would you like\nyour Proto-Legend to be based?")
    dynmultichoice(0, 0, FALSE, 5, 0, DYN_MULTICHOICE_CB_NONE,
        "KANTO",
        "JOHTO",
        "HOENN",
        "SINNOH",
        "UNOVA",
        "KALOS",
		"ALOLA",
		//"GALAR",
		//"PALDEA",
        "{COLOR GREEN}EXIT")
	closemessage
	if (var(VAR_RESULT) > NUM_REGION_CHOICES - 1) {
        goto(RustboroCity_DevonCorp_4F_EventScript_DrParkerEnd)
    }

	message("And which genetic line are you\ninterested in?")
	switch (var(VAR_RESULT)) {
		case REGION_CHOICE_KANTO:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectKanto)
		case REGION_CHOICE_JOHTO:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectJohto)
		case REGION_CHOICE_HOENN:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectHoenn)
		case REGION_CHOICE_SINNOH:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectSinnoh)
		case REGION_CHOICE_UNOVA:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectUnova)
		case REGION_CHOICE_KALOS:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectKalos)
		case REGION_CHOICE_ALOLA:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectAlola)
		//case REGION_CHOICE_GALAR:
			//goto(RustboroCity_DevonCorp_4F_EventScript_SelectGalar)
		//case REGION_CHOICE_PALDEA:
			//goto(RustboroCity_DevonCorp_4F_EventScript_SelectPaldea)
		default:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectRegion)
	}
}

script RustboroCity_DevonCorp_4F_EventScript_SelectKanto {
	multichoice(0, 0, MULTI_MINI_LEGEND_KANTO, FALSE)
	closemessage

	switch (var(VAR_RESULT)) {
		case KANTO_CHOICE_MEWTWO:
			goto_if_set(FLAG_OBTAINED_MEWTWO_LINE, RustboroCity_DevonCorp_4F_EventScript_HasMon) // already obtained from this line?
			multichoice(0, 0, MULTI_MINI_LEGEND_MEWTWO, FALSE)  // show choices for this line
			closemessage

			if (var(VAR_RESULT) > NUM_CHOICES_MEWTWO - 1) {  // exit or back button?
				goto(RustboroCity_DevonCorp_4F_EventScript_SelectKanto)  // back to line choices
			}
			addvar(VAR_RESULT, OFFSET_MEWTWO)  // offset to get correct mon ID
			break
		case KANTO_CHOICE_BIRDS:
			goto_if_set(FLAG_OBTAINED_BIRD_LINE, RustboroCity_DevonCorp_4F_EventScript_HasMon)
			multichoice(0, 0, MULTI_MINI_LEGEND_BIRDS, FALSE)
			closemessage

			if (var(VAR_RESULT) > NUM_CHOICES_BIRDS - 1) {
				goto(RustboroCity_DevonCorp_4F_EventScript_SelectKanto)
			}
			addvar(VAR_RESULT, OFFSET_BIRDS)
			break
		default:
			goto(RustboroCity_DevonCorp_4F_EventScript_SelectRegion)
	}

	copyvar(VAR_TEMP_1, VAR_RESULT)
	goto(RustboroCity_DevonCorp_4F_EventScript_OfferShiny)
}

